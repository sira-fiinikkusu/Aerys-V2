# Copy to .env and fill in — .env is gitignored, never commit it.

# Required: real Anthropic API key (console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides (defaults in src/aerys_v2/config.py)
# MODEL=claude-opus-4-8
# SOUL_FILE_PATH=config/soul.md
# OTLP_ENDPOINT=

# Optional: Discord gateway spike (1c)
# DISCORD_BOT_TOKEN=your-dev-bot-token
# DISCORD_GUILD_ID=1421592685730594956
# DISCORD_REPLY_CHANNEL_IDS=1480365115684688127

# Durable conversation threads (Phase-2 heart). Unset = in-memory (tests/CI).
# DATABASE_URL=postgresql://sira:PASSWORD@192.168.1.231:5432/aerys_v2
