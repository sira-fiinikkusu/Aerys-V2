# Copy to .env and fill in — .env is gitignored, never commit it.

# Required: real Anthropic API key (console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides (defaults in src/aerys_v2/config.py)
# MODEL=claude-opus-4-8
# SOUL_FILE_PATH=config/soul.md
# OTLP_ENDPOINT=

# Optional: Discord gateway spike (1c) — `aerys-v2 --discord`
# DISCORD_BOT_TOKEN=your-dev-bot-token
# DISCORD_GUILD_ID=your_guild_id_here
# DISCORD_REPLY_CHANNEL_IDS=000000000000000000

# Optional: Telegram gateway (aiogram long-polling) — `aerys-v2 --telegram`
# TELEGRAM_BOT_TOKEN=your-botfather-token
# TELEGRAM_CHAT_IDS=-1001234567890   # csv of group chat ids ("" = DMs only, groups by mention)

# Durable conversation threads (Phase-2 heart). Unset = in-memory (tests/CI).
# DATABASE_URL=postgresql://user:PASSWORD@localhost:5432/aerys_v2

# HTTP door (--serve): Bearer token + port for /ask (HA voice, reTerminal, curl)
# API_TOKEN=generate-something-long
# API_PORT=8300

# Model backend: "api" (metered) or "oauth" (Max subscription via Agent SDK)
# MODEL_BACKEND=oauth
